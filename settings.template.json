{
  "env": {
    "CLAUDE_CODE_DISABLE_TERMINAL_TITLE": "1"
  },
  "attribution": {
    "commit": "",
    "pr": ""
  },
  "permissions": {
    "allow": [
      "mcp__reposynapse__annotate",
      "mcp__reposynapse__generate_project_docs",
      "mcp__reposynapse__get_diagnostics",
      "mcp__reposynapse__get_project_context",
      "mcp__reposynapse__list_files",
      "mcp__reposynapse__read_file",
      "mcp__reposynapse__read_file_outline",
      "mcp__reposynapse__read_file_symbol",
      "mcp__reposynapse__search_in_file",
      "mcp__reposynapse__search_in_project",
      "mcp__reposynapse__search_symbol",
      "mcp__reposynapse__patch_file",
      "mcp__reposynapse__add_import",
      "mcp__reposynapse__replace_symbol",
      "mcp__reposynapse__insert_after_symbol",
      "mcp__reposynapse__batch_rename",
      "mcp__reposynapse__remove_dead_code",
      "mcp__reposynapse__get_complexity"
    ]
  },
  "model": "opusplan",
  "hooks": {
    "Notification": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.vibe-island/bin/vibe-island-bridge --source claude"
          }
        ]
      },
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "node \"$HOME/.pixel-agents/hooks/claude-hook.js\"",
            "timeout": 5
          }
        ]
      }
    ],
    "PermissionRequest": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.vibe-island/bin/vibe-island-bridge --source claude",
            "timeout": 86400
          }
        ]
      },
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "node \"$HOME/.pixel-agents/hooks/claude-hook.js\"",
            "timeout": 5
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "npx tsc --noEmit --pretty 2>&1 | head -20",
            "statusMessage": "Type-check after edits"
          }
        ]
      },
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.vibe-island/bin/vibe-island-bridge --source claude"
          }
        ]
      },
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "node \"$HOME/.pixel-agents/hooks/claude-hook.js\"",
            "timeout": 5
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.vibe-island/bin/vibe-island-bridge --source claude"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.vibe-island/bin/vibe-island-bridge --source claude"
          }
        ]
      },
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "node \"$HOME/.pixel-agents/hooks/claude-hook.js\"",
            "timeout": 5
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.vibe-island/bin/vibe-island-bridge --source claude"
          }
        ]
      },
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "node \"$HOME/.pixel-agents/hooks/claude-hook.js\"",
            "timeout": 5
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.vibe-island/bin/vibe-island-bridge --source claude"
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "echo '{\"hookSpecificOutput\": {\"hookEventName\": \"SessionStart\", \"additionalContext\": \"Active skills — apply automatically without being asked: (1) brainstorming: before any new feature, component, or creative work; (2) concise-output: keep responses short and direct; (3) dispatching-parallel-agents: when 2+ tasks are independent, run them in parallel; (4) find-skills: when user asks how to do something that might have a skill; (5) model-selector: choose the right Claude model for task complexity; (6) planning-with-files: for complex tasks requiring >5 tool calls, create a plan file first; (7) realistic-testing: prefer real tests with real data over mocks; (8) reposynapse-explore: use reposynapse MCP tools first when exploring the codebase; (9) verification: after code changes, verify they work.\"}}'",
            "statusMessage": "Cargando skills de sesión..."
          }
        ]
      },
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "node \"$HOME/.pixel-agents/hooks/claude-hook.js\"",
            "timeout": 5
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.vibe-island/bin/vibe-island-bridge --source claude"
          }
        ]
      },
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "node \"$HOME/.pixel-agents/hooks/claude-hook.js\"",
            "timeout": 5
          }
        ]
      }
    ],
    "SubagentStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.vibe-island/bin/vibe-island-bridge --source claude"
          }
        ]
      },
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "node \"$HOME/.pixel-agents/hooks/claude-hook.js\"",
            "timeout": 5
          }
        ]
      }
    ],
    "SubagentStop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.vibe-island/bin/vibe-island-bridge --source claude"
          }
        ]
      },
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "node \"$HOME/.pixel-agents/hooks/claude-hook.js\"",
            "timeout": 5
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.claude/hooks/SkillActivationHook/skill-activation-prompt.sh"
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.vibe-island/bin/vibe-island-bridge --source claude"
          }
        ]
      },
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "node \"$HOME/.pixel-agents/hooks/claude-hook.js\"",
            "timeout": 5
          }
        ]
      }
    ],
    "PostToolUseFailure": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "node \"$HOME/.pixel-agents/hooks/claude-hook.js\"",
            "timeout": 5
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "bash $HOME/.claude/statusline-command.sh"
  },
  "enabledPlugins": {
    "context7@claude-plugins-official": true,
    "miskills@miskills-marketplace": true,
    "skill-creator@claude-plugins-official": true,
    "warp@claude-code-warp": true
  },
  "extraKnownMarketplaces": {
    "miskills-marketplace": {
      "source": {
        "source": "directory",
        "path": "$HOME/.claude/plugins/marketplaces/miskills-marketplace"
      }
    },
    "claude-code-warp": {
      "source": {
        "source": "github",
        "repo": "warpdotdev/claude-code-warp"
      }
    }
  },
  "language": "Español",
  "effortLevel": "medium"
}
